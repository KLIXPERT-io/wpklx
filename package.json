{
  "name": "wpklx",
  "version": "0.1.0",
  "description": "KLX WordPress CLI — a dynamic, fault-tolerant CLI for the WordPress REST API",
  "type": "module",
  "bin": {
    "wpklx": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/wpklx",
    "typecheck": "tsc --noEmit",
    "lint": "bunx --bun oxlint"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
